---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import ImageSlide from '@/components/ImageSlide/react';
import commingSoonImage from '@/images/portfolio/comming_soon.webp';

type Props = {
	image?: ImageMetadata;
	imageAlt?: string;
	title?: string;
};

const { image, imageAlt, title } = Astro.props as Props;

const displayImage = image ?? commingSoonImage;
const displayImageAlt = imageAlt ?? 'Coming Soon';
---

<ImageSlide client:load image={displayImage.src} imageAlt={displayImageAlt} title={title}>
	<Image class='link__image' width={800} src={displayImage} alt={displayImageAlt} />
</ImageSlide>

<style is:global>
	body.modal-open {
		overflow: hidden;
	}
</style>
