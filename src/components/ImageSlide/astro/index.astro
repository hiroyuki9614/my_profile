---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { Splide, SplideSlide } from 'astro-splide';
import '@splidejs/splide/css';
import ImageSlide from '@/components/ImageSlide/react';
import commingSoonImage from '@/images/portfolio/comming_soon.webp';

type Props = {
	image: ImageMetadata;
	slideImages?: ImageMetadata[];
	imageAlt?: string;
	title?: string;
};

const { image, slideImages, imageAlt, title } = Astro.props as Props;

const displayImage = image ? image : commingSoonImage;
const displayImageAlt = imageAlt ?? 'Coming Soon';
---

<ImageSlide client:load image={displayImage.src} imageAlt={displayImageAlt} title={title}>
	<Splide aria-label='ポートフォリオ画像一覧' class='not-content'>
		{
			slideImages && slideImages.length > 0 ? (
				slideImages.map((slideImage, index) => (
					<SplideSlide>
						<Image class='link__image' width={400} height={300} src={slideImage} alt={`${title}のスライド - ${index + 1}`} />
					</SplideSlide>
				))
			) : (
				<SplideSlide>
					<Image class='link__image' width={400} height={300} src={commingSoonImage} alt='Coming Soon' />
				</SplideSlide>
			)
		}
	</Splide>
</ImageSlide>

<style is:global>
	body.modal-open {
		overflow: hidden;
	}

	.link__image {
		border-radius: 1rem;
	}

	.splide__slide {
		display: flex;
		justify-content: center; /* 左右の中央揃え */
	}
</style>
