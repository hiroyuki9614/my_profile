---
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import ShowCategory from '@/components/ShowCategory/index.astro';
import { formatDate } from '@/utils/formatDate';
import 'github-markdown-css/github-markdown.css';
import '@/styles/global.css';

const { pathname } = Astro.url;
let slug = '';

// /posts/SLUG または /posts/SLUG/ からSLUGを抽出
const slugMatch = pathname.match(/\/posts\/([^\/]+)\/?$/);
if (slugMatch && slugMatch[1]) {
	slug = slugMatch[1];
}
const { frontmatter } = Astro.props;

const allPosts = await getCollection('posts', ({ data }) => data.status === 'published');
const sortedPosts = allPosts.sort((a, b) => {
	return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

const currentIndex = sortedPosts.findIndex((post) => post.id === slug);
const prevPost = currentIndex + 1 < sortedPosts.length ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
	<article>
		<div class='container'>
			<div class='content flex flex-col'>
				<a href='/posts' class='underline font-bold mt-2 mb-5'>← 一覧へ戻る</a>
				<ShowCategory category={frontmatter.category} />
				<h1 class='font-extrabold'>{frontmatter.title}</h1>
				<div class='metadata mb-6 text-right'>
					<time class=''>投稿日：{formatDate(frontmatter.date)}</time>
				</div>
				<div class='markdown-body'>
					<slot />
				</div>
			</div>
		</div>
		<nav class='post-navigation flex justify-center'>
			<div class='post-navigation__links w-[60%]'>
				{
					prevPost ? (
						<a href={`/posts/${prevPost.id}`} class='post-navigation__prev'>
							<span class='post-navigation__label --prev'>← 前の記事</span>
							<span class='post-navigation__title'>{prevPost.data.title}</span>
						</a>
					) : (
						<div class='post-navigation__prev'>
							<span class='post-navigation__label --prev'>← 前の記事</span>
						</div>
					)
				}

				{
					nextPost ? (
						<a href={`/posts/${nextPost.id}`} class='post-navigation__next'>
							<span class='post-navigation__label --next'>次の記事 →</span>
							<span class='post-navigation__title'>{nextPost.data.title}</span>
						</a>
					) : (
						<div class='post-navigation__next'>
							<span class='post-navigation__label --next'>次の記事 →</span>
						</div>
					)
				}
			</div>
		</nav>
	</article>

	<style>
		:root {
			--bgColor-default: #f5f5f5;
		}

		@media (prefers-color-scheme: dark) {
			:root {
				--bgColor-default: #f5f5f5;
			}
		}

		.markdown-body {
			color: #0f0f0f;
			background: #f5f5f5;
			min-height: 100vh;
			margin: 0;
			list-style: 2 !important;
			background-color: #f5f5f5;
		}

		.markdown-body table tr {
			background: white !important;
		}

		.markdown-body ul {
			list-style-type: disc !important;
			padding-left: 2rem !important;
		}

		.markdown-body ol {
			list-style-type: decimal !important;
			padding-left: 2rem !important;
		}

		.category {
			display: inline-flex; /* または display: flex; */
			justify-content: center; /* 水平方向の中央寄せ */
			align-items: center; /* 垂直方向の中央寄せ */
			height: 20px;
			width: 4rem;
			/* background-color: aqua; */
			border-radius: 10px;
		}

		.container {
			max-width: 1200px;
			margin: 0 auto;
			padding: 0 20px;
			display: flex;
			justify-content: center;
		}

		.content {
			width: 80%;
			max-width: 800px;
			margin: 0 auto;
			padding: 20px 0;
		}

		@media (max-width: 768px) {
			.content {
				width: 90%;
			}
		}

		/* 既存のスタイルに追加 */
		.post-navigation {
			margin: 4rem 0;
			padding: 2rem 0;
			border-top: 1px solid #eaeaea;
		}

		.post-navigation__links {
			display: flex;
			justify-content: space-between;
			gap: 2rem;
		}

		.post-navigation__next {
			text-align: right;
		}
		.post-navigation__prev {
			text-align: left;
			justify-content: flex-start;
		}

		.post-navigation__prev,
		.post-navigation__next {
			flex: 1;
			text-decoration: none;
			color: inherit;
			padding: 1rem;
			border: 1px solid #eaeaea;
			border-radius: 0.5rem;
			transition: background-color 0.2s;
		}

		.post-navigation__prev:hover,
		.post-navigation__next:hover {
			background-color: #f5f5f5;
		}

		.post-navigation__label {
			display: block;
			color: #666;
			font-size: 0.875rem;
		}

		.post-navigation__title {
			display: block;
			font-weight: 600;
			margin-top: 0.5rem;
		}
	</style>
</BaseLayout>
